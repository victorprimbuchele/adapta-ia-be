// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  lastLoginAt  DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  classes Class[]

  @@map("users")
}

/// Dado de referência fixo (sem cadastro dinâmico no MVP — ver Épico 2).
/// Populado via seed (`prisma/seed.ts`).
model School {
  id        String   @id @default(cuid())
  name      String
  city      String
  state     String   @map("state")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  classes Class[]

  @@map("schools")
}

/// Dado de referência fixo (sem cadastro dinâmico no MVP — ver Épico 2).
/// Populado via seed (`prisma/seed.ts`). `sortOrder` define a ordem de
/// exibição nas listagens (ex.: do 1º ano ao 9º ano).
model Grade {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @unique @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  classes Class[]

  @@map("grades")
}

/// Turma — vinculada a uma escola e uma série de referência, com o
/// professor responsável sendo sempre o usuário autenticado que a criou
/// (ver Épico 2, BE-E2.3).
model Class {
  id        String   @id @default(cuid())
  name      String
  schoolId  String   @map("school_id")
  gradeId   String   @map("grade_id")
  teacherId String   @map("teacher_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school  School @relation(fields: [schoolId], references: [id])
  grade   Grade  @relation(fields: [gradeId], references: [id])
  teacher User   @relation(fields: [teacherId], references: [id])

  @@index([schoolId])
  @@index([gradeId])
  @@index([teacherId])
  @@map("classes")
}
