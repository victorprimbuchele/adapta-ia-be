// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  lastLoginAt  DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  classes               Class[]
  userClasses           UserClass[]
  userLearningProfiles  UserLearningProfile[]
  homeworks             Homework[]
  deliveries            Delivery[]
  deliveryRecipients    DeliveryRecipient[] @relation("DeliveryRecipientStudent")

  @@map("users")
}

/// Dado de referência fixo (sem cadastro dinâmico no MVP — ver Épico 2).
/// Populado via seed (`prisma/seed.ts`).
model School {
  id        String   @id @default(cuid())
  name      String
  city      String
  state     String   @map("state")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  classes Class[]

  @@map("schools")
}

/// Dado de referência fixo (sem cadastro dinâmico no MVP — ver Épico 2).
/// Populado via seed (`prisma/seed.ts`). `sortOrder` define a ordem de
/// exibição nas listagens (ex.: do 1º ano ao 9º ano).
model Grade {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @unique @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  classes Class[]

  @@map("grades")
}

/// Disciplina — dado de referência fixo para o formulário estruturado de
/// homework (ver Épico 4, BE-E4.6). Sem cadastro dinâmico no MVP: populado
/// via seed (`prisma/seed.ts`). `sortOrder` define a ordem de exibição.
model Subject {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @unique @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("subjects")
}

/// Turma — vinculada a uma escola e uma série de referência, com o
/// professor responsável sendo sempre o usuário autenticado que a criou
/// (ver Épico 2, BE-E2.3).
model Class {
  id        String    @id @default(cuid())
  name      String
  schoolId  String    @map("school_id")
  gradeId   String    @map("grade_id")
  teacherId String    @map("teacher_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  school  School @relation(fields: [schoolId], references: [id])
  grade   Grade  @relation(fields: [gradeId], references: [id])
  teacher User   @relation(fields: [teacherId], references: [id])

  enrollments UserClass[]
  homeworks   Homework[]

  @@index([schoolId])
  @@index([gradeId])
  @@index([teacherId])
  @@map("classes")
}

/// Vinculação de um aluno (`User`) a uma turma (`Class`) — ver Épico 3,
/// BE-E3.1. Aluno é, do ponto de vista do domínio de autenticação, um
/// `User` como qualquer outro; `UserClass` é a tabela de junção N:N entre
/// alunos e turmas (um aluno pode estar em mais de uma turma).
model UserClass {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  classId   String   @map("class_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id])
  class Class @relation(fields: [classId], references: [id])

  /// Um mesmo aluno nunca é vinculado duas vezes à mesma turma.
  @@unique([userId, classId])
  @@index([userId])
  @@index([classId])
  @@map("user_classes")
}

/// Perfil de aprendizagem (simples ou composto) — catálogo de referência
/// usado na adaptação de homeworks (ver Épico 3, BE-E3.2). Dificuldades
/// combinadas são modeladas como um único perfil composto (ex.: "Dislexia
/// + baixa visão"), não como múltiplos vínculos simultâneos. O campo
/// `prompt` (JSONB) carrega as instruções enviadas à LLM na adaptação.
model LearningProfile {
  id        String   @id @default(cuid())
  name      String   @unique
  prompt    Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userLearningProfiles UserLearningProfile[]
  homeworks            Homework[]

  @@map("learning_profiles")
}

/// Vinculação aluno (`User`) ↔ perfil de aprendizagem. No MVP cada aluno
/// tem no máximo um perfil ativo: ao vincular um novo, o anterior é
/// substituído (ver Épico 3, BE-E3.2). A tabela de junção permite evoluir
/// para N:N em versões futuras removendo o `@@unique([userId])`.
model UserLearningProfile {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  learningProfileId String   @map("learning_profile_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user            User            @relation(fields: [userId], references: [id])
  learningProfile LearningProfile @relation(fields: [learningProfileId], references: [id])

  /// MVP: no máximo 1 perfil ativo por aluno.
  @@unique([userId])
  @@index([learningProfileId])
  @@map("user_learning_profiles")
}

/// Arquivo persistido em storage (Épico 5, BE-E5.7; PDF — Épico 6, BE-E6.2).
enum FileType {
  audio
  pdf
}

model File {
  id        String   @id @default(cuid())
  type      FileType
  /// Caminho/chave no storage (filesystem local no MVP).
  path      String
  mimeType  String   @map("mime_type")
  sizeBytes Int      @map("size_bytes")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  homeworkAudio   Homework? @relation("HomeworkAudioFile")
  homeworkContent Homework? @relation("HomeworkContentFile")

  @@index([type])
  @@map("files")
}

/// Homework — material created by the teacher via the structured form
/// (Epic 4, BE-E4.1 / ADR 012). The "generator homework" is the original
/// (`homeworkId` and `learningProfileId` null, `isDraft` true on create).
/// Adaptations point to the generator via `homeworkId` and carry the
/// target profile's `learningProfileId`. `glossary` (JSON) holds the
/// structured glossary on adapted variants (Épico 5, BE-E5.4). Always
/// linked to a class (`classId`) so activities can be listed per turma
/// (BE-E4.5). Variantes com TTS podem apontar para `File` tipo audio via
/// `audioFileId` (BE-E5.7).
model Homework {
  id                String   @id @default(cuid())
  title             String
  content           String
  subject           String?
  question          String?
  /// Glossário estruturado `[{ term, definition }]` na variante adaptada;
  /// null na geradora ou quando o perfil não pede glossário (BE-E5.4).
  glossary          Json?
  isDraft           Boolean  @default(true) @map("is_draft")
  /// Null na geradora; na variante aponta para a homework geradora (BE-E5.5).
  homeworkId        String?  @map("homework_id")
  /// Null na geradora; na variante identifica o perfil adaptado (BE-E5.5).
  learningProfileId String?  @map("learning_profile_id")
  /// Null na geradora / sem TTS; na variante com áudio aponta para `File`
  /// tipo `audio` (BE-E5.7).
  audioFileId       String?  @unique @map("audio_file_id")
  /// Null na geradora; na variante aponta para `File` tipo `pdf` (BE-E6.2).
  contentFileId     String?  @unique @map("content_file_id")
  classId           String   @map("class_id")
  teacherId         String   @map("teacher_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  parentHomework  Homework?        @relation("HomeworkAdaptations", fields: [homeworkId], references: [id])
  adaptations     Homework[]       @relation("HomeworkAdaptations")
  learningProfile LearningProfile? @relation(fields: [learningProfileId], references: [id])
  audioFile       File?            @relation("HomeworkAudioFile", fields: [audioFileId], references: [id])
  contentFile     File?            @relation("HomeworkContentFile", fields: [contentFileId], references: [id])
  class           Class            @relation(fields: [classId], references: [id])
  teacher         User             @relation(fields: [teacherId], references: [id])
  deliveries               Delivery[]
  deliveryRecipientVariant DeliveryRecipient[] @relation("DeliveryRecipientVariant")

  /// Uma variante por par geradora+perfil (BE-E5.5).
  @@unique([homeworkId, learningProfileId])
  @@index([teacherId])
  @@index([homeworkId])
  @@index([learningProfileId])
  @@index([classId])
  @@map("homeworks")
}

/// Status de envio de um destinatário individual (Épico 6, BE-E6.1).
enum DeliveryRecipientStatus {
  pendente
  enviado
  falhou
}

/// Status agregado do envio (`Sending` — Épico 7, BE-E7.1).
enum DeliveryStatus {
  pendente
  agendado
}

/// Um "envio" de uma homework geradora — dispara um e-mail por aluno
/// matriculado na turma com perfil de aprendizagem vinculado, usando a
/// variante adaptada correspondente (Épico 7, BE-E7.1). Assíncrono: a API
/// só cria o registro e enfileira; o worker envia de fato.
model Delivery {
  id         String         @id @default(cuid())
  homeworkId String         @map("homework_id")
  teacherId  String         @map("teacher_id")
  status     DeliveryStatus @default(agendado)
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  homework   Homework            @relation(fields: [homeworkId], references: [id])
  teacher    User                @relation(fields: [teacherId], references: [id])
  recipients DeliveryRecipient[]

  @@index([homeworkId])
  @@index([teacherId])
  @@map("deliveries")
}

/// Destinatário individual de um `Delivery` — um aluno + a variante
/// adaptada que deve receber (Épico 6, BE-E6.1). `falhou` sem
/// `variantHomeworkId` utilizável significa que o perfil do aluno não
/// tinha uma variante pronta no momento do envio.
model DeliveryRecipient {
  id                String                  @id @default(cuid())
  deliveryId        String                  @map("delivery_id")
  studentId         String                  @map("student_id")
  /// Snapshot do nome/e-mail no momento do envio (registro histórico —
  /// não muda retroativamente se o aluno editar o cadastro depois).
  studentName       String                  @map("student_name")
  studentEmail      String                  @map("student_email")
  variantHomeworkId String?                 @map("variant_homework_id")
  status            DeliveryRecipientStatus @default(pendente)
  failedReason      String?                 @map("failed_reason")
  sentAt            DateTime?               @map("sent_at")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")

  delivery        Delivery  @relation(fields: [deliveryId], references: [id])
  student         User      @relation("DeliveryRecipientStudent", fields: [studentId], references: [id])
  variantHomework Homework? @relation("DeliveryRecipientVariant", fields: [variantHomeworkId], references: [id])

  /// Um aluno nunca é destinatário duplicado no mesmo envio.
  @@unique([deliveryId, studentId])
  @@index([deliveryId])
  @@index([studentId])
  @@map("delivery_recipients")
}
