// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  lastLoginAt  DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  classes               Class[]
  userClasses           UserClass[]
  userLearningProfiles  UserLearningProfile[]
  homeworks             Homework[]

  @@map("users")
}

/// Dado de referência fixo (sem cadastro dinâmico no MVP — ver Épico 2).
/// Populado via seed (`prisma/seed.ts`).
model School {
  id        String   @id @default(cuid())
  name      String
  city      String
  state     String   @map("state")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  classes Class[]

  @@map("schools")
}

/// Dado de referência fixo (sem cadastro dinâmico no MVP — ver Épico 2).
/// Populado via seed (`prisma/seed.ts`). `sortOrder` define a ordem de
/// exibição nas listagens (ex.: do 1º ano ao 9º ano).
model Grade {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @unique @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  classes Class[]

  @@map("grades")
}

/// Disciplina — dado de referência fixo para o formulário estruturado de
/// homework (ver Épico 4, BE-E4.6). Sem cadastro dinâmico no MVP: populado
/// via seed (`prisma/seed.ts`). `sortOrder` define a ordem de exibição.
model Subject {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @unique @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("subjects")
}

/// Turma — vinculada a uma escola e uma série de referência, com o
/// professor responsável sendo sempre o usuário autenticado que a criou
/// (ver Épico 2, BE-E2.3).
model Class {
  id        String    @id @default(cuid())
  name      String
  schoolId  String    @map("school_id")
  gradeId   String    @map("grade_id")
  teacherId String    @map("teacher_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  school  School @relation(fields: [schoolId], references: [id])
  grade   Grade  @relation(fields: [gradeId], references: [id])
  teacher User   @relation(fields: [teacherId], references: [id])

  enrollments UserClass[]
  homeworks   Homework[]

  @@index([schoolId])
  @@index([gradeId])
  @@index([teacherId])
  @@map("classes")
}

/// Vinculação de um aluno (`User`) a uma turma (`Class`) — ver Épico 3,
/// BE-E3.1. Aluno é, do ponto de vista do domínio de autenticação, um
/// `User` como qualquer outro; `UserClass` é a tabela de junção N:N entre
/// alunos e turmas (um aluno pode estar em mais de uma turma).
model UserClass {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  classId   String   @map("class_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id])
  class Class @relation(fields: [classId], references: [id])

  /// Um mesmo aluno nunca é vinculado duas vezes à mesma turma.
  @@unique([userId, classId])
  @@index([userId])
  @@index([classId])
  @@map("user_classes")
}

/// Perfil de aprendizagem (simples ou composto) — catálogo de referência
/// usado na adaptação de homeworks (ver Épico 3, BE-E3.2). Dificuldades
/// combinadas são modeladas como um único perfil composto (ex.: "Dislexia
/// + baixa visão"), não como múltiplos vínculos simultâneos. O campo
/// `prompt` (JSONB) carrega as instruções enviadas à LLM na adaptação.
model LearningProfile {
  id        String   @id @default(cuid())
  name      String   @unique
  prompt    Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userLearningProfiles UserLearningProfile[]
  homeworks            Homework[]

  @@map("learning_profiles")
}

/// Vinculação aluno (`User`) ↔ perfil de aprendizagem. No MVP cada aluno
/// tem no máximo um perfil ativo: ao vincular um novo, o anterior é
/// substituído (ver Épico 3, BE-E3.2). A tabela de junção permite evoluir
/// para N:N em versões futuras removendo o `@@unique([userId])`.
model UserLearningProfile {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  learningProfileId String   @map("learning_profile_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user            User            @relation(fields: [userId], references: [id])
  learningProfile LearningProfile @relation(fields: [learningProfileId], references: [id])

  /// MVP: no máximo 1 perfil ativo por aluno.
  @@unique([userId])
  @@index([learningProfileId])
  @@map("user_learning_profiles")
}

/// Homework — material created by the teacher via the structured form
/// (Epic 4, BE-E4.1 / ADR 012). The "generator homework" is the original
/// (`homeworkId` and `learningProfileId` null, `isDraft` true on create).
/// Adaptations point to the generator via `homeworkId` and carry the
/// target profile's `learningProfileId`. `glossary` (JSON) holds the
/// structured glossary on adapted variants (Épico 5, BE-E5.4). Always
/// linked to a class (`classId`) so activities can be listed per turma
/// (BE-E4.5).
model Homework {
  id                String   @id @default(cuid())
  title             String
  content           String
  /// Glossário estruturado `[{ term, definition }]` na variante adaptada;
  /// null na geradora ou quando o perfil não pede glossário (BE-E5.4).
  glossary          Json?
  isDraft           Boolean  @default(true) @map("is_draft")
  /// Null na geradora; na variante aponta para a homework geradora (BE-E5.5).
  homeworkId        String?  @map("homework_id")
  /// Null na geradora; na variante identifica o perfil adaptado (BE-E5.5).
  learningProfileId String?  @map("learning_profile_id")
  classId           String   @map("class_id")
  teacherId         String   @map("teacher_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  parentHomework  Homework?        @relation("HomeworkAdaptations", fields: [homeworkId], references: [id])
  adaptations     Homework[]       @relation("HomeworkAdaptations")
  learningProfile LearningProfile? @relation(fields: [learningProfileId], references: [id])
  class           Class            @relation(fields: [classId], references: [id])
  teacher         User             @relation(fields: [teacherId], references: [id])

  /// Uma variante por par geradora+perfil (BE-E5.5).
  @@unique([homeworkId, learningProfileId])
  @@index([teacherId])
  @@index([homeworkId])
  @@index([learningProfileId])
  @@index([classId])
  @@map("homeworks")
}
